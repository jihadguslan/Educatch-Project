; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="EduCatch"
config/version="1.2"
run/main_scene="uid://dpejwyit6xyxr"
config/features=PackedStringArray("4.5", "Forward Plus")
boot_splash/show_image=false
config/icon="uid://dddnbdvxy414k"

[autoload]

Global="*res://Script/Global.gd"
DatabaseManager="*res://Scene/database_manager.tscn"
ScreenManager="*res://Scene/Screen Manager.tscn"

[display]

window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

Cheat={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":true,"shift_pressed":true,"ctrl_pressed":true,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":67,"key_label":0,"unicode":99,"location":0,"echo":false,"script":null)
]
}

[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

2d_physics/layer_1="Fish"
2d_physics/layer_2="Wall"

[rendering]

textures/canvas_textures/default_texture_filter=0
textures/vram_compression/import_etc2_astc=true
